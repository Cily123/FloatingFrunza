<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="FloatingFrunza" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/FloatingFrunza" prefix_auto="1" extension_auto="1" />
				<Option working_dir="$(TARGET_OUTPUT_DIR)" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Option use_console_runner="0" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
				<Linker>
					<Add option="-mconsole" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/FloatingFrunza" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
			<Target title="rainlib">
				<Option output="bin/rainlib/FloatingFrunza" prefix_auto="1" extension_auto="1" />
				<Option working_dir="" />
				<Option object_output="obj/rainlib/" />
				<Option type="2" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add directory="C:/raylib/w64devkit/include" />
		</Compiler>
		<Linker>
			<Add option="-mwindows" />
			<Add library="../../../../../programe/CodeBlocks/MinGW/x86_64-w64-mingw32/lib/libraylib.a" />
			<Add library="../../../../../programe/CodeBlocks/MinGW/x86_64-w64-mingw32/lib/libwinmm.a" />
			<Add library="../../../../../programe/CodeBlocks/MinGW/x86_64-w64-mingw32/lib/libopengl32.a" />
			<Add library="../../../../../programe/CodeBlocks/MinGW/x86_64-w64-mingw32/lib/libgdi32.a" />
			<Add directory="C:/raylib/w64devkit/lib" />
		</Linker>
